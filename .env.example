# Copia este archivo como .env y llena los valores reales
# cp .env.example .env

# Django
SECRET_KEY=cambia-esto-por-una-clave-secreta-larga
DEBUG=False
ALLOWED_HOSTS=ti.grupogonza.phanalytics.com.mx

# URL base para correos (sin / al final)
# Desarrollo: http://localhost:8005
# Producción: https://ti.grupogonza.phanalytics.com.mx
SITE_URL=https://ti.grupogonza.phanalytics.com.mx

# Base de datos SQL Server
DB_HOST=ip-o-hostname-del-servidor-sql
DB_NAME=nombre_de_la_base
DB_USER=usuario_sql
DB_PASS=password_sql
DB_PORT=1433

# Resend API (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
DEFAULT_FROM_EMAIL=TI Grupo Gonza <ti@phanalytics.com.mx>

# Google Chat Webhook (Space Tickets TI — notificaciones generales)
GOOGLE_CHAT_WEBHOOK=https://chat.googleapis.com/v1/spaces/XXXXX/messages?key=...&token=...

# Google Chat Webhook (Space Pool — tickets disponibles para auto-asignación)
GOOGLE_CHAT_WEBHOOK_POOL=https://chat.googleapis.com/v1/spaces/YYYYY/messages?key=...&token=...
