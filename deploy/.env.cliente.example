# Plantilla de variables por cliente. nuevo-cliente.sh genera el .env real.
# RELLENA los secretos (SECRET_KEY, DB_PASS, password del superusuario).

DEBUG=False
SECRET_KEY=GENERA_UNO_NUEVO_LARGO_Y_ALEATORIO

# El subdominio del cliente (lo usa ALLOWED_HOSTS y CSRF)
ALLOWED_HOSTS=__SUBDOMINIO__
SITE_URL=https://__SUBDOMINIO__

# Base de datos del cliente (en el droplet de SQL Server, IP privada)
DB_HOST=10.0.0.0
DB_PORT=1433
DB_NAME=ierp___SLUG__
DB_USER=ierp_app
DB_PASS=CAMBIA_ESTO

# Superusuario inicial (se crea solo al primer arranque)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@__SUBDOMINIO__
DJANGO_SUPERUSER_PASSWORD=CAMBIA_ESTO

# Correo (opcional)
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=no-reply@ierp.mx
