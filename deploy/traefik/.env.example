# Copia este archivo a .env (en deploy/traefik/) y rellénalo.
# ACME_EMAIL: correo para los avisos de Let's Encrypt.
# DO_AUTH_TOKEN: token de API de DigitalOcean con permiso de escritura en DNS
#                (Networking > API > Generate New Token, scope: read+write).
ACME_EMAIL=tu-correo@dominio.com
DO_AUTH_TOKEN=dop_v1_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
